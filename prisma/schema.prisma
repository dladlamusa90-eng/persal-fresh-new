datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum BankAccountType {
  CHEQUE
  SAVINGS
  TRANSMISSION
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  persalNumber String?  @unique
  phone        String?
  idNumber     String?
  bankName     String?
  accountNumber String?
  accountType  BankAccountType?
  branchCode   String?
  profileImage String?
  address      String?
  points       Int      @default(0)
  password      String
  role          Role     @default(USER)
  isBurned      Boolean  @default(false)
  burnedAt      DateTime?
  bankVerified    Boolean  @default(false)
  stitchAccountId String?
  loanApplicationDraft LoanApplicationDraft?
  loans         Loan[]
  loginOtps     LoginOtp[]
  passwordResetOtps PasswordResetOtp[]
  createdAt     DateTime @default(now())

  @@index([role])
  @@index([isBurned])
  @@index([createdAt])
}

model LoginOtp {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model PasswordResetOtp {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Loan {
  id        String     @id @default(cuid())
  amount    Float
  termDays  Int
  applicationData Json?
  applicationDocuments Json?
  grossSalary Float?
  disposableIncome Float?
  applicantFullName String?
  applicantEmail String?
  applicantPhone String?
  applicantIdNumber String?
  applicantPersalNumber String?
  applicantBankName String?
  applicantAccountNumber String?
  applicantAccountType BankAccountType?
  applicantBranchCode String?
  status    LoanStatus
  rejectionReason String?
  debitMandateAccepted Boolean @default(false)
  debitMandateAcceptedAt DateTime?
  debitMandateReference String?
  disbursementSentAt DateTime?
  disbursementReference String?
  disbursementMode String?
  stitchMandateId     String?
  stitchMandateStatus String?
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())

  @@index([status])
  @@index([userId, status])
  @@index([createdAt])
}

model LoanApplicationDraft {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data       Json?
  documents  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([updatedAt])
}
