generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String                @id @default(uuid())
  fullName                   String
  email                      String                @unique
  persalNumber               String?               @unique
  password                   String
  createdAt                  DateTime              @default(now())
  accountNumber              String?
  bankName                   String?
  idNumber                   String?
  phone                      String?
  role                       Role                  @default(USER)
  profileImage               String?
  isBurned                   Boolean               @default(false)
  burnedAt                   DateTime?
  points                     Int                   @default(0)
  accountType                BankAccountType?
  branchCode                 String?
  bankVerified               Boolean               @default(false)
  stitchAccountId            String?
  address                    String?
  isDeleted                  Boolean               @default(false)
  deletedAt                  DateTime?
  faceIdExternalUserId       String?               @unique
  faceIdEnrolled             Boolean               @default(false)
  faceIdStatus               String?
  faceIdVerifiedAt           DateTime?
  faceIdLastCheckedAt        DateTime?
  faceIdLastError            String?
  applicationStatus          ApplicationStatus     @default(PENDING)
  applicationApprovedAt      DateTime?
  applicationRejectedAt      DateTime?
  applicationRejectionReason String?
  faceIdRegistrationPhoto    String?
  faceIdLastLivePhoto        String?
  faceIdLastMatchPassed      Boolean               @default(false)
  faceIdLastMatchedAt        DateTime?
  employmentStatus           String?
  employmentGrossIncome      String?
  employmentNetIncome        String?
  incomeFrequency            String?
  salaryDay                  String?
  referralCode               String?               @unique
  referralDiscountPct        Int                   @default(0)
  usedReferralCode           String?
  notifications              AdminNotification[]
  loans                      Loan?
  loanApplicationDraft       LoanApplicationDraft?
  loginOtps                  LoginOtp[]
  passwordResetOtps          PasswordResetOtp[]
  pointEvents                UserPointsEvent[]

  @@index([role])
  @@index([isBurned])
  @@index([isDeleted])
  @@index([faceIdStatus])
  @@index([createdAt])
}

model AdminNotification {
  id          String                @id @default(cuid())
  userId      String
  type        AdminNotificationType @default(MESSAGE)
  title       String
  body        String
  readAt      DateTime?
  createdAt   DateTime              @default(now())
  createdById String?
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model UserPointsEvent {
  id           String          @id @default(cuid())
  userId       String
  type         PointsEventType
  pointsDelta  Int
  balanceAfter Int
  description  String?
  loanId       String?
  actorUserId  String?
  createdAt    DateTime        @default(now())
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
}

model LoginOtp {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model PasswordResetOtp {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Loan {
  id                            String           @id @default(cuid())
  amount                        Float
  termDays                      Int
  status                        LoanStatus
  userId                        String           @unique(map: "loan_one_open_per_user_idx")
  createdAt                     DateTime         @default(now())
  rejectionReason               String?
  debitMandateAccepted          Boolean          @default(false)
  debitMandateAcceptedAt        DateTime?
  debitMandateReference         String?
  disbursementSentAt            DateTime?
  disbursementReference         String?
  disbursementMode              String?
  stitchMandateId               String?
  stitchMandateStatus           String?
  grossSalary                   Float?
  disposableIncome              Float?
  applicantFullName             String?
  applicantEmail                String?
  applicantPhone                String?
  applicantIdNumber             String?
  applicantPersalNumber         String?
  applicantBankName             String?
  applicantAccountNumber        String?
  applicantAccountType          BankAccountType?
  applicantBranchCode           String?
  applicationData               Json?
  applicationDocuments          Json?
  faceRegistrationPhotoSnapshot String?
  faceVerificationPhoto         String?
  faceMatchPassed               Boolean          @default(false)
  faceMatchCheckedAt            DateTime?
  user                          User             @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId, status])
  @@index([createdAt])
}

model LoanApplicationDraft {
  id        String   @id @default(cuid())
  userId    String   @unique
  data      Json?
  documents Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

enum Role {
  USER
  ADMIN
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum BankAccountType {
  CHEQUE
  SAVINGS
  TRANSMISSION
}

enum PointsEventType {
  ON_TIME_REPAYMENT
  ADMIN_ADJUSTMENT
}

enum AdminNotificationType {
  MESSAGE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}
